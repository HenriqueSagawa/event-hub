PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/event_hub?schema=public"

# Authentication
JWT_SECRET="your-super-secret-key"

# SMTP (Email)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="your-password"
SMTP_FROM="Event Hub <noreply@example.com>"